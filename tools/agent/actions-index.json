{
  "version": "1.0.0",
  "base_url": "http://127.0.0.1:8800",
  "playbook": [
    "GET /health",
    "For destructive actions: prefer dry_run=true first",
    "Mutating bulk actions auto-record undo snapshot when dry_run=false",
    "After mutation: GET /products and GET /totals",
    "On failure: POST /actions/history/undo",
    "Before automation execute: GET /automation/status must be idle/ready"
  ],
  "actions": [
    {
      "name": "health.check",
      "method": "GET",
      "path": "/health",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["status == ok"],
      "errors": ["5xx if backend down"],
      "rollback": null
    },
    {
      "name": "products.list",
      "method": "GET",
      "path": "/products",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["items is array"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "products.create",
      "method": "POST",
      "path": "/products",
      "risk": "low",
      "dry_run": false,
      "auto_snapshot": false,
      "body": {
        "nome": "string",
        "codigo": "string",
        "quantidade": 1,
        "preco": "10,00",
        "categoria": "",
        "marca": ""
      },
      "verify": ["201 item.ordering_key present", "GET /products contains key"],
      "errors": ["422 invalid price"],
      "rollback": "products.delete or history.undo if snapshot taken"
    },
    {
      "name": "products.update",
      "method": "PATCH",
      "path": "/products/{ordering_key}",
      "risk": "medium",
      "dry_run": false,
      "auto_snapshot": false,
      "body": {"partial ProductPatchPayload": true},
      "verify": ["item returned", "GET matches fields"],
      "errors": ["404", "422"],
      "rollback": "history.undo if snapshot taken"
    },
    {
      "name": "products.delete",
      "method": "DELETE",
      "path": "/products/{ordering_key}",
      "risk": "high",
      "dry_run": false,
      "auto_snapshot": true,
      "body": null,
      "verify": ["status deleted", "GET without key"],
      "errors": ["404"],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "products.clear",
      "method": "DELETE",
      "path": "/products",
      "risk": "critical",
      "dry_run": true,
      "dry_run_param": "query dry_run=true",
      "auto_snapshot": true,
      "body": null,
      "verify": ["removed count", "if not dry_run: GET items empty"],
      "errors": [],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "totals.get",
      "method": "GET",
      "path": "/totals",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["atual.quantidade present"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "brands.list",
      "method": "GET",
      "path": "/brands",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["marcas is array"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "brands.add",
      "method": "POST",
      "path": "/brands",
      "risk": "low",
      "dry_run": false,
      "auto_snapshot": false,
      "body": {"nome": "string"},
      "verify": ["marcas contains nome"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "margin.get",
      "method": "GET",
      "path": "/settings/margin",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["percentual present"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "margin.save",
      "method": "POST",
      "path": "/settings/margin",
      "risk": "medium",
      "dry_run": false,
      "auto_snapshot": false,
      "body": {"percentual": 100},
      "verify": ["GET /settings/margin matches"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "actions.apply_category",
      "method": "POST",
      "path": "/actions/apply-category",
      "risk": "high",
      "dry_run": true,
      "dry_run_param": "body dry_run=true",
      "auto_snapshot": true,
      "body": {"valor": "Masculino", "dry_run": false},
      "verify": ["total", "if not dry_run sample categoria"],
      "errors": [],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "actions.apply_brand",
      "method": "POST",
      "path": "/actions/apply-brand",
      "risk": "high",
      "dry_run": true,
      "dry_run_param": "body dry_run=true",
      "auto_snapshot": true,
      "body": {"valor": "Marca X", "dry_run": false},
      "verify": ["total"],
      "errors": [],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "actions.join_duplicates",
      "method": "POST",
      "path": "/actions/join-duplicates",
      "risk": "high",
      "dry_run": true,
      "dry_run_param": "query dry_run=true",
      "auto_snapshot": true,
      "body": null,
      "verify": ["originais", "resultantes", "removidos"],
      "errors": [],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "actions.join_grades",
      "method": "POST",
      "path": "/actions/join-grades",
      "risk": "high",
      "dry_run": true,
      "dry_run_param": "body dry_run=true",
      "auto_snapshot": true,
      "body": {"keys": [], "dry_run": false},
      "verify": ["originais", "resultantes", "removidos"],
      "errors": [],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "actions.reorder",
      "method": "POST",
      "path": "/actions/reorder",
      "risk": "low",
      "dry_run": false,
      "auto_snapshot": false,
      "body": {"keys": ["key1", "key2"]},
      "verify": ["total", "GET order matches keys"],
      "errors": [],
      "rollback": "history.undo if snapshot taken"
    },
    {
      "name": "actions.format_codes",
      "method": "POST",
      "path": "/actions/format-codes",
      "risk": "high",
      "dry_run": true,
      "dry_run_param": "body dry_run=true",
      "auto_snapshot": true,
      "body": {"remover_zeros_a_esquerda": true, "dry_run": false},
      "verify": ["alterados", "total"],
      "errors": [],
      "rollback": "POST /actions/restore-original-codes or history.undo"
    },
    {
      "name": "actions.restore_original_codes",
      "method": "POST",
      "path": "/actions/restore-original-codes",
      "risk": "medium",
      "dry_run": false,
      "auto_snapshot": true,
      "body": {},
      "verify": ["restaurados"],
      "errors": [],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "actions.apply_margin",
      "method": "POST",
      "path": "/actions/apply-margin",
      "risk": "high",
      "dry_run": true,
      "dry_run_param": "body dry_run=true",
      "auto_snapshot": true,
      "body": {"percentual": 100, "dry_run": false},
      "verify": ["total_atualizados"],
      "errors": ["400 Margem invalida"],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "actions.create_set",
      "method": "POST",
      "path": "/actions/create-set",
      "risk": "high",
      "dry_run": false,
      "auto_snapshot": true,
      "body": {"key_a": "k1", "key_b": "k2"},
      "verify": ["created", "removed"],
      "errors": ["400"],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "actions.improve_descriptions",
      "method": "POST",
      "path": "/actions/improve-descriptions",
      "risk": "medium",
      "dry_run": true,
      "dry_run_param": "body dry_run=true",
      "auto_snapshot": true,
      "body": {"remover_numeros": true, "remover_especiais": false, "remover_termos": [], "dry_run": false},
      "verify": ["modificados"],
      "errors": ["400 no cleanup option"],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "history.get",
      "method": "GET",
      "path": "/actions/history",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["can_undo", "can_redo"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "history.snapshot",
      "method": "POST",
      "path": "/actions/history/snapshot",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": {"clear_redo": true},
      "verify": ["undo_count increased"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "history.undo",
      "method": "POST",
      "path": "/actions/history/undo",
      "risk": "medium",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["restored true", "GET products restored"],
      "errors": [],
      "rollback": "POST /actions/history/redo"
    },
    {
      "name": "history.redo",
      "method": "POST",
      "path": "/actions/history/redo",
      "risk": "medium",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["restored true"],
      "errors": [],
      "rollback": "POST /actions/history/undo"
    },
    {
      "name": "import.romaneio.start",
      "method": "POST",
      "path": "/actions/import-romaneio",
      "risk": "medium",
      "dry_run": false,
      "auto_snapshot": false,
      "body": "multipart file",
      "verify": ["job_id"],
      "errors": ["400 empty file"],
      "rollback": "history.undo after import if snapshot taken"
    },
    {
      "name": "import.romaneio.status",
      "method": "GET",
      "path": "/actions/import-romaneio/status/{job_id}",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["stage", "job_id"],
      "errors": ["404"],
      "rollback": null
    },
    {
      "name": "import.romaneio.result",
      "method": "GET",
      "path": "/actions/import-romaneio/result/{job_id}",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["status", "total_itens"],
      "errors": ["404", "409 still running"],
      "rollback": null
    },
    {
      "name": "import.local_experiment",
      "method": "POST",
      "path": "/actions/import-romaneio-local-experiment",
      "risk": "medium",
      "dry_run": false,
      "auto_snapshot": false,
      "body": "multipart file",
      "verify": ["total_itens"],
      "errors": ["400", "422 no importable items"],
      "rollback": "history.undo if snapshot taken"
    },
    {
      "name": "grades.parser.start",
      "method": "POST",
      "path": "/actions/parser-grades",
      "risk": "medium",
      "dry_run": false,
      "auto_snapshot": false,
      "body": "multipart file",
      "verify": ["job_id"],
      "errors": ["400"],
      "rollback": null
    },
    {
      "name": "export.jsonl",
      "method": "GET",
      "path": "/actions/export-json",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["content-type application/x-ndjson"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "automation.status",
      "method": "GET",
      "path": "/automation/status",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["estado present"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "automation.execute",
      "method": "POST",
      "path": "/automation/execute",
      "risk": "critical",
      "dry_run": false,
      "auto_snapshot": false,
      "needs_human": true,
      "body": null,
      "verify": ["GET /automation/status", "poll until idle"],
      "errors": ["400 environment/config"],
      "rollback": "POST /automation/cancel"
    },
    {
      "name": "automation.execute_complete",
      "method": "POST",
      "path": "/automation/execute-complete",
      "risk": "critical",
      "dry_run": false,
      "auto_snapshot": false,
      "needs_human": true,
      "body": null,
      "verify": ["status polling"],
      "errors": ["400"],
      "rollback": "POST /automation/cancel"
    },
    {
      "name": "automation.cancel",
      "method": "POST",
      "path": "/automation/cancel",
      "risk": "low",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["status idle"],
      "errors": [],
      "rollback": null
    },
    {
      "name": "automation.grades.run",
      "method": "POST",
      "path": "/automation/grades/run",
      "risk": "critical",
      "dry_run": false,
      "auto_snapshot": false,
      "needs_human": true,
      "body": {"grades": {"M": 1}},
      "verify": ["status polling"],
      "errors": ["400"],
      "rollback": "POST /automation/grades/stop"
    },
    {
      "name": "catalog.sizes",
      "method": "GET",
      "path": "/catalog/sizes",
      "risk": "none",
      "dry_run": false,
      "auto_snapshot": false,
      "body": null,
      "verify": ["sizes array"],
      "errors": [],
      "rollback": null
    }
  ]
}
